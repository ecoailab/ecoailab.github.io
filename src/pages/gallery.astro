---
import Layout from '../layouts/Layout.astro';

const memories = [
  { src: '/assets/gallery/gallery-1.jpg', alt: 'EcoAI Lab 연구 활동' },
  { src: '/assets/gallery/gallery-2.jpg', alt: 'EcoAI Lab 학회 참석' },
  { src: '/assets/gallery/gallery-3.jpg', alt: 'EcoAI Lab 팀' },
  ...Array.from({ length: 13 }, (_, i) => ({
    src: `/assets/gallery/memories-${i + 1}.jpg`,
    alt: `EcoAI Lab Memories ${i + 1}`,
  })),
];

const awards = Array.from({ length: 19 }, (_, i) => ({
  src: `/assets/gallery/awards-${i + 1}.jpg`,
  alt: `EcoAI Lab Awards ${i + 1}`,
}));

const all = [...memories, ...awards];
---

<Layout title="Gallery">
  <section
    class="mx-auto w-full max-w-6xl px-6 pt-32 pb-8 md:px-10 md:pt-40"
    aria-labelledby="gallery-heading"
    data-reveal
  >
    <p class="mono-label mb-4 !text-azure">// GALLERY</p>
    <h1
      id="gallery-heading"
      class="font-display font-semibold tracking-[-0.015em]"
      style="font-size: clamp(2.25rem, 4.5vw, 3.5rem)"
    >
      연구실의 순간들
    </h1>
    <div class="relative mt-8 h-px w-full bg-line" aria-hidden="true">
      <span class="absolute -top-px left-0 h-[3px] w-12 bg-azure"></span>
    </div>
  </section>

  <!-- Memories -->
  <section
    class="mx-auto w-full max-w-6xl px-6 py-16 md:px-10 md:py-24"
    aria-labelledby="memories-heading"
    data-reveal
  >
    <p class="mono-label mb-4 !text-azure">// MEMORIES</p>
    <h2
      id="memories-heading"
      class="font-display font-semibold tracking-[-0.01em]"
      style="font-size: clamp(1.75rem, 3vw, 2.5rem)"
    >
      Memories
    </h2>
    <div class="relative mt-6 mb-10 h-px w-full bg-line" aria-hidden="true">
      <span class="absolute -top-px left-0 h-[3px] w-12 bg-azure"></span>
    </div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        memories.map((img, i) => (
          <button
            type="button"
            class="gallery-item group overflow-hidden rounded-xl border border-line"
            data-index={i}
            aria-label={`${img.alt} — 크게 보기`}
          >
            <img
              src={img.src}
              alt={img.alt}
              width="640"
              height="480"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
          </button>
        ))
      }
    </div>
  </section>

  <!-- Awards -->
  <section
    class="mx-auto w-full max-w-6xl px-6 py-16 md:px-10 md:py-24"
    aria-labelledby="awards-heading"
    data-reveal
  >
    <p class="mono-label mb-4 !text-azure">// AWARDS</p>
    <h2
      id="awards-heading"
      class="font-display font-semibold tracking-[-0.01em]"
      style="font-size: clamp(1.75rem, 3vw, 2.5rem)"
    >
      Awards
    </h2>
    <div class="relative mt-6 mb-10 h-px w-full bg-line" aria-hidden="true">
      <span class="absolute -top-px left-0 h-[3px] w-12 bg-azure"></span>
    </div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        awards.map((img, i) => (
          <button
            type="button"
            class="gallery-item group overflow-hidden rounded-xl border border-line"
            data-index={memories.length + i}
            aria-label={`${img.alt} — 크게 보기`}
          >
            <img
              src={img.src}
              alt={img.alt}
              width="640"
              height="480"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
          </button>
        ))
      }
    </div>
  </section>

  <!-- Note -->
  <section
    class="mx-auto w-full max-w-6xl px-6 pb-24 md:px-10 md:pb-36"
    aria-label="Gallery note"
    data-reveal
  >
    <div class="card p-6">
      <p class="text-sm text-dim">더 많은 사진은 계속 업데이트됩니다.</p>
    </div>
  </section>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[90] hidden items-center justify-center bg-abyss/92 p-6 backdrop-blur-md"
    role="dialog"
    aria-modal="true"
    aria-label="사진 크게 보기"
  >
    <button
      id="lightbox-close"
      type="button"
      aria-label="닫기"
      class="absolute right-5 top-5 inline-flex h-11 w-11 items-center justify-center rounded-full border border-line-strong text-frost transition-colors hover:border-azure hover:text-sky-glow"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M6 6l12 12M18 6 6 18" stroke-linecap="round"></path>
      </svg>
    </button>
    <button
      id="lightbox-prev"
      type="button"
      aria-label="이전 사진"
      class="absolute left-3 top-1/2 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-line-strong text-frost transition-colors hover:border-azure hover:text-sky-glow md:left-6"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M15 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
    <button
      id="lightbox-next"
      type="button"
      aria-label="다음 사진"
      class="absolute right-3 top-1/2 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-line-strong text-frost transition-colors hover:border-azure hover:text-sky-glow md:right-6"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="m9 5 7 7-7 7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
    <figure class="flex max-h-full max-w-4xl flex-col items-center gap-4">
      <img id="lightbox-img" src={all[0]?.src ?? '/assets/gallery/gallery-1.jpg'} alt="" class="max-h-[78dvh] w-auto rounded-xl border border-line object-contain" />
      <figcaption id="lightbox-caption" class="font-mono text-sm text-mist"></figcaption>
    </figure>
  </div>
</Layout>

<script>
  import { gsap, prefersReducedMotion } from '../lib/motion';

  interface GalleryImage {
    src: string;
    alt: string;
  }

  const items = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-item'));
  const images: GalleryImage[] = items.map((btn) => {
    const img = btn.querySelector('img');
    return { src: img?.getAttribute('src') ?? '', alt: img?.getAttribute('alt') ?? '' };
  });

  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const caption = document.getElementById('lightbox-caption');
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  let current = 0;
  let lastFocused: HTMLElement | null = null;

  const show = (index: number) => {
    current = (index + images.length) % images.length;
    const image = images[current];
    if (!image || !lightboxImg || !caption) return;
    lightboxImg.src = image.src;
    lightboxImg.alt = image.alt;
    caption.textContent = `${current + 1} / ${images.length} — ${image.alt}`;
    if (!prefersReducedMotion()) {
      gsap.fromTo(lightboxImg, { opacity: 0, scale: 0.96 }, { opacity: 1, scale: 1, duration: 0.35, ease: 'power2.out' });
    }
  };

  const open = (index: number) => {
    if (!lightbox) return;
    lastFocused = document.activeElement as HTMLElement | null;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
    show(index);
    closeBtn?.focus();
  };

  const close = () => {
    if (!lightbox) return;
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
    lastFocused?.focus();
  };

  items.forEach((btn, i) => {
    btn.addEventListener('click', () => open(i));
  });
  closeBtn?.addEventListener('click', close);
  prevBtn?.addEventListener('click', () => show(current - 1));
  nextBtn?.addEventListener('click', () => show(current + 1));
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });
  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });

  if (!prefersReducedMotion()) {
    items.forEach((item) => {
      gsap.fromTo(
        item,
        { opacity: 0.4, scale: 0.94 },
        {
          opacity: 1,
          scale: 1,
          duration: 0.9,
          ease: 'power3.out',
          scrollTrigger: { trigger: item, start: 'top 88%' },
        },
      );
    });
  }
</script>
