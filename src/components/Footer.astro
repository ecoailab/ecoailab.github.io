---
import { site } from '../data/site';

const links = [
  { href: '/people', label: 'People' },
  { href: '/research', label: 'Research' },
  { href: '/publications', label: 'Publications' },
  { href: '/news', label: 'News' },
  { href: '/gallery', label: 'Gallery' },
];
---

<footer class="border-t border-line">
  <div class="mx-auto w-full max-w-6xl px-6 py-16 md:px-10 md:py-20">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <a href="/" class="inline-flex items-center gap-3">
          <img src={site.logo} alt="" width="36" height="36" class="h-9 w-9 object-contain" />
          <span class="font-display text-lg font-semibold tracking-tight text-frost">
            EcoAI <span class="text-azure">Lab</span>
          </span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-mist">
          {site.tagline}.<br />
          {site.affiliationEn}
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a
            href={site.github}
            target="_blank"
            rel="noopener noreferrer"
            class="chip transition-colors hover:border-azure hover:text-sky-glow">GitHub</a
          >
          <a
            href={site.scholar}
            target="_blank"
            rel="noopener noreferrer"
            class="chip transition-colors hover:border-azure hover:text-sky-glow">Google Scholar</a
          >
        </div>
      </div>

      <nav aria-label="Footer">
        <h2 class="mono-label mb-4">Sitemap</h2>
        <ul class="space-y-2.5 text-sm">
          {
            links.map((link) => (
              <li>
                <a href={link.href} class="text-mist transition-colors hover:text-frost">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="mono-label mb-4">Contact</h2>
        <ul class="space-y-2.5 text-sm text-mist">
          <li>
            <a href={`mailto:${site.email}`} class="transition-colors hover:text-sky-glow">{site.email}</a>
          </li>
          <li>{site.tel}</li>
          <li>{site.room}</li>
          <li>{site.affiliation}</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col gap-3 border-t border-line pt-6 font-mono text-xs text-dim md:flex-row md:items-center md:justify-between"
    >
      <span>© {new Date().getFullYear()} EcoAI Lab, Hanbat National University</span>
      <span>EYES ON THE SKY · INNOVATE FOR THE FUTURE</span>
    </div>
  </div>
</footer>
