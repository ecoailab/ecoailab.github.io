---
import { coreTech } from '../data/site';
---

<section class="mx-auto w-full max-w-6xl px-6 py-24 md:px-10 md:py-36" aria-labelledby="tech-heading">
  <div class="mb-14 md:mb-20" data-reveal>
    <p class="mono-label mb-4 !text-azure">// CORE_TECHNOLOGIES</p>
    <h2
      id="tech-heading"
      class="font-display font-semibold tracking-[-0.01em]"
      style="font-size: clamp(1.75rem, 3vw, 2.5rem)"
    >
      다섯 가지 핵심 기술
    </h2>
    <div class="relative mt-8 h-px w-full bg-line" aria-hidden="true">
      <span class="absolute -top-px left-0 h-[3px] w-12 bg-azure"></span>
    </div>
  </div>

  <div class="tech-accordion flex flex-col gap-3 lg:h-[360px] lg:flex-row" data-reveal>
    {
      coreTech.map((tech, i) => (
        <button
          type="button"
          class:list={['tech-slice group relative overflow-hidden rounded-xl border border-line bg-panel text-left lg:min-h-0', i === 0 && 'tech-open']}
          aria-expanded={i === 0 ? 'true' : 'false'}
          data-index={i}
        >
          <span class="tech-collapsed pointer-events-none flex items-center gap-3 p-5 lg:absolute lg:inset-0 lg:flex-col lg:items-center lg:justify-start lg:p-5">
            <span class="font-mono text-sm font-medium text-azure">{String(i + 1).padStart(2, '0')}</span>
            <span class="font-mono text-xs font-medium uppercase tracking-[0.14em] text-mist lg:mt-3 lg:[writing-mode:vertical-rl]">
              {tech.title}
            </span>
          </span>
          <span class="tech-expanded pointer-events-none flex h-full flex-col gap-3 p-6 lg:justify-between lg:p-7">
            <span class="font-mono text-xs text-azure">{String(i + 1).padStart(2, '0')}</span>
            <span>
              <span class="block font-display text-xl font-semibold text-frost lg:text-2xl">{tech.title}</span>
              <span class="mt-3 block text-sm leading-relaxed text-mist">{tech.description}</span>
            </span>
          </span>
        </button>
      ))
    }
  </div>
</section>

<style>
  .tech-slice {
    flex: 1 1 0;
    transition:
      flex-grow 500ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 250ms ease-out;
  }
  .tech-slice .tech-expanded {
    opacity: 0;
    transition: opacity 300ms ease-out;
  }
  .tech-slice.tech-open {
    border-color: var(--color-line-strong);
  }
  .tech-slice.tech-open .tech-collapsed {
    opacity: 0;
  }
  .tech-slice.tech-open .tech-expanded {
    opacity: 1;
    transition-delay: 120ms;
  }

  @media (min-width: 1024px) {
    .tech-slice {
      flex-grow: 1;
    }
    .tech-slice.tech-open {
      flex-grow: 3.4;
    }
    .tech-slice .tech-expanded {
      opacity: 0;
    }
  }

  @media (max-width: 1023px) {
    .tech-slice .tech-expanded {
      display: none;
    }
    .tech-slice.tech-open .tech-collapsed {
      display: none;
    }
    .tech-slice.tech-open .tech-expanded {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tech-slice {
      transition: none;
    }
  }
</style>

<script>
  const slices = Array.from(document.querySelectorAll<HTMLButtonElement>('.tech-slice'));
  const accordion = document.querySelector('.tech-accordion');

  const open = (index: number) => {
    slices.forEach((slice, i) => {
      const isOpen = i === index;
      slice.classList.toggle('tech-open', isOpen);
      slice.setAttribute('aria-expanded', String(isOpen));
    });
  };

  slices.forEach((slice, i) => {
    slice.addEventListener('mouseenter', () => open(i));
    slice.addEventListener('focus', () => open(i));
    slice.addEventListener('click', () => open(i));
    slice.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        slices[(i + 1) % slices.length]?.focus();
      }
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        slices[(i - 1 + slices.length) % slices.length]?.focus();
      }
    });
  });

  accordion?.addEventListener('mouseleave', () => open(0));
</script>
