---
import { projects } from '../data/projects';

const ongoing = projects.filter((p) => p.status === 'ongoing').slice(0, 5);
---

<section
  id="ongoing-research"
  class="mx-auto w-full max-w-6xl px-6 py-24 md:px-10 md:py-36"
  aria-labelledby="ongoing-heading"
>
  <div class="grid gap-12 lg:grid-cols-[minmax(0,5fr)_minmax(0,7fr)] lg:gap-16">
    <div class="lg:self-start" data-pin-left>
      <p class="mono-label mb-4 !text-azure">// ONGOING_RESEARCH</p>
      <h2
        id="ongoing-heading"
        class="font-display font-semibold tracking-[-0.01em]"
        style="font-size: clamp(1.75rem, 3vw, 2.5rem)"
      >
        지금 진행 중인 연구
      </h2>
      <p class="mt-5 max-w-md text-lg leading-relaxed text-mist">
        양자배터리, 스마트팩토리, 인터랙티브 공연 AI — 국가과제와 산학 협력이 지금 이 순간에도 돌아가고 있습니다.
      </p>
      <a href="/research" class="btn-ghost mt-8">All Projects</a>
      <div class="relative mt-10 h-px w-full bg-line lg:hidden" aria-hidden="true">
        <span class="absolute -top-px left-0 h-[3px] w-12 bg-azure"></span>
      </div>
    </div>

    <div class="flex flex-col gap-5">
      {
        ongoing.map((project) => (
          <article class="card card-hover p-7" data-pin-card data-spotlight>
            <div class="flex flex-wrap items-center gap-3">
              <span class="chip !border-success/40 !text-success">Ongoing</span>
              <span class="font-mono text-xs text-dim">{project.period}</span>
              <span class="font-mono text-xs text-dim">·</span>
              <span class="font-mono text-xs text-mist">{project.org}</span>
            </div>
            <h3 class="mt-4 font-display text-lg font-semibold leading-snug text-frost">
              {project.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-mist">{project.summary}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger, prefersReducedMotion } from '../lib/motion';

  if (!prefersReducedMotion()) {
    const mm = gsap.matchMedia();

    mm.add('(min-width: 1024px)', () => {
      const section = document.getElementById('ongoing-research');
      const left = section?.querySelector<HTMLElement>('[data-pin-left]');
      if (!section || !left) return;

      const trigger = ScrollTrigger.create({
        trigger: section,
        start: 'top 96px',
        end: 'bottom bottom-=120',
        pin: left,
        pinSpacing: false,
      });

      return () => trigger.kill();
    });

    gsap.utils.toArray<HTMLElement>('[data-pin-card]').forEach((card) => {
      gsap.fromTo(
        card,
        { opacity: 0, y: 42 },
        {
          opacity: 1,
          y: 0,
          duration: 0.85,
          ease: 'power3.out',
          scrollTrigger: { trigger: card, start: 'top 88%' },
        },
      );
    });
  }
</script>
