---
import { site } from '../data/site';

const links = [
  { href: '/people', label: 'People' },
  { href: '/research', label: 'Research' },
  { href: '/publications', label: 'Publications' },
  { href: '/news', label: 'News' },
  { href: '/gallery', label: 'Gallery' },
];

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(`${href}/`);
---

<header class="fixed inset-x-0 top-4 z-50 flex justify-center px-4 md:top-6">
  <nav
    id="site-nav"
    aria-label="Primary"
    class="glass-pill flex w-full max-w-3xl items-center justify-between gap-4 rounded-full py-2 pl-4 pr-2 transition-transform duration-300"
  >
    <a href="/" class="flex items-center gap-2.5" aria-label={`${site.name} home`}>
      <img src={site.logo} alt="" width="30" height="30" class="h-[30px] w-[30px] object-contain" />
      <span class="font-display text-[15px] font-semibold tracking-tight text-frost">
        EcoAI <span class="text-azure">Lab</span>
      </span>
    </a>

    <ul class="hidden items-center gap-1 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'relative rounded-full px-3.5 py-1.5 text-sm transition-colors duration-150',
                isActive(link.href) ? 'text-frost' : 'text-mist hover:text-frost',
              ]}
            >
              {link.label}
              {isActive(link.href) && (
                <span class="absolute inset-x-3.5 -bottom-0.5 h-px bg-azure" aria-hidden="true" />
              )}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="EcoAI Lab GitHub"
        class="hidden h-9 w-9 items-center justify-center rounded-full text-mist transition-colors duration-150 hover:text-frost md:inline-flex"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.17c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.76.11 3.05.73.81 1.18 1.83 1.18 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.04.77 2.1v3.11c0 .3.21.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
      </a>
      <a
        href={`mailto:${site.email}`}
        class="btn-primary hidden !px-5 !py-2 md:inline-flex"
      >
        Contact
      </a>
      <button
        id="menu-button"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full text-frost md:hidden"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 5.5h14M3 10h14M3 14.5h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden flex-col justify-center bg-abyss/95 px-8 backdrop-blur-xl"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
>
  <ul class="flex flex-col gap-2">
    {
      links.map((link, i) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'menu-link block border-b border-line py-4 font-display text-3xl font-semibold transition-colors',
              isActive(link.href) ? 'text-azure' : 'text-frost',
            ]}
            style={`--i:${i}`}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
  <a href={`mailto:${site.email}`} class="btn-primary mt-10 self-start">Contact</a>
</div>

<script>
  const button = document.getElementById('menu-button');
  const menu = document.getElementById('mobile-menu');

  const setMenu = (open: boolean) => {
    if (!button || !menu) return;
    button.setAttribute('aria-expanded', String(open));
    button.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menu.classList.toggle('hidden', !open);
    menu.classList.toggle('flex', open);
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) {
      const first = menu.querySelector<HTMLAnchorElement>('a');
      first?.focus();
    }
  };

  button?.addEventListener('click', () => {
    setMenu(button.getAttribute('aria-expanded') !== 'true');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMenu(false);
  });

  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  document.addEventListener('astro:before-swap', () => setMenu(false));
</script>
